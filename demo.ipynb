   "source": [
    "## 4. Feature Engineering — TF-IDF\n",
    "\n",
    "We turn each title's genres + overview into a numeric vector using **TF-IDF**.\n",
    "\n",
    "- **TF (Term Frequency):** how often a word appears in *this* document\n",
    "- **IDF (Inverse Document Frequency):** penalises words that appear everywhere (like \"the\")\n",
    "- Result: common genre words like "action" become meaningful signals"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Build the 'soup' — genres weighted 3x higher than overview\n",
    "df['soup'] = (\n",
    "    (df['genres'] + ' ') * 3\n",
    "    + df['overview'].str[:300]\n",
    "    + ' ' + df['type']\n",
    ")\n",
    "\n",
    "print('Sample soup for Attack on Titan:')\n",
    "print(df[df['title'] == 'Attack on Titan']['soup'].values[0])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Fit TF-IDF\n",
    "tfidf = TfidfVectorizer(stop_words='english')\n",
    "tfidf_matrix = tfidf.fit_transform(df['soup'])\n",
    "\n",
    "print(f'TF-IDF matrix shape: {tfidf_matrix.shape}')\n",
    "print(f'  → {tfidf_matrix.shape[0]} titles × {tfidf_matrix.shape[1]} unique words')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Show the top TF-IDF features (most distinctive words)\n",
    "feature_names = tfidf.get_feature_names_out()\n",
    "dense = tfidf_matrix.toarray()\n",
    "top_features = pd.DataFrame({\n",
    "    'word': feature_names,\n",
    "    'mean_tfidf': dense.mean(axis=0)\n",
    "}).sort_values('mean_tfidf', ascending=False).head(20)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 4))\n",
    "bars = ax.barh(top_features['word'], top_features['mean_tfidf'],\n",
    "               color=cm.viridis(np.linspace(0.3, 0.9, 20)))\n",
    "ax.set_title('Top 20 Most Distinctive Words (by mean TF-IDF score)')\n",
    "ax.set_xlabel('Mean TF-IDF Score')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Cosine Similarity\n",
    "\n",
    "Now we compute how similar every pair of titles is."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "cosine_sim = cosine_similarity(tfidf_matrix, tfidf_matrix)\n",
    "print(f'Similarity matrix shape: {cosine_sim.shape}')\n",
    "\n",
    "# Build index: title → row number\n",
    "indices = pd.Series(df.index, index=df['title'].str.lower())\n",
    "print('\\nSample similarities for Attack on Titan:')\n",
    "\n",
    "idx = indices['attack on titan']\n",
    "sim_scores = sorted(enumerate(cosine_sim[idx]), key=lambda x: x[1], reverse=True)\n",
    "sim_df = pd.DataFrame([(df.iloc[i]['title'], df.iloc[i]['type'], round(s, 3))\n",
    "                        for i, s in sim_scores[1:6]],\n",
    "                       columns=['title', 'type', 'similarity'])\n",
    "sim_df"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualise the full similarity heatmap\n",
    "fig, ax = plt.subplots(figsize=(14, 12))\n",
    "sns.heatmap(\n",
    "    cosine_sim,\n",
    "    xticklabels=df['title'],\n",
    "    yticklabels=df['title'],\n",
    "    cmap='plasma',\n",
    "    ax=ax,\n",
    "    linewidths=0.5,\n",
    ")\n",
    "ax.set_title('Cosine Similarity Between All Titles', fontsize=14)\n",
    "plt.xticks(rotation=90, fontsize=7)\n",
    "plt.yticks(fontsize=7)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
